# Copy to .env and set real values. Never commit .env.
# All hosted services must be in a UK or EU region.

# Environment: development or production
NODE_ENV="development"

# PostgreSQL connection string (UK or EU region)
DATABASE_URL="postgresql://isms:CHANGE_ME@localhost:5432/isms?schema=public"

# OIDC identity provider (confirm provider and values, see docs/configuration-to-confirm.md C6 and C7).
# Leave OIDC_ISSUER_URL blank in development to enable the local sign in.
OIDC_ISSUER_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="http://localhost:4000/auth/callback"

# Object storage for document files (S3 compatible, UK or EU region).
# Leave blank in development to store files on the local filesystem.
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# Email for review notifications (UK or EU mail service). Leave blank to log only.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="isms@example.org"

# API
PORT="4000"
SESSION_SECRET="change-me-to-a-long-random-value"
CORS_ORIGIN="http://localhost:5173"
