{
  "name": "cloud-ax-isms-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud.ax ISMS REST API and data layer",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/seed/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "9.0.1",
    "@fastify/multipart": "8.3.0",
    "@prisma/client": "5.22.0",
    "archiver": "7.0.1",
    "dotenv": "16.4.5",
    "exceljs": "4.4.0",
    "fastify": "4.28.1",
    "nodemailer": "6.9.15",
    "pdfkit": "0.15.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/node": "20.16.11",
    "@types/nodemailer": "6.4.16",
    "@types/pdfkit": "0.13.5",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
